{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "viraltrim",
  "main": "worker/index.ts",
  "compatibility_date": "2025-04-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "viraltrim-db",
      "database_id": "26af0a14-55a5-44cb-9f1d-5df4b5fea25c"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "273e8ac85e68401fbe46f8f76067005d"
    },
    {
      "binding": "CACHE",
      "id": "e4b1b252c9744233af37a22c3a57c10b"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "viraltrim-media"
    }
  ],
  "triggers": {
    "crons": ["0 0 * * *"]
  },
  "vars": {
    "APP_URL": "https://viraltrim.codedmotion.studio",
    "ALLOWED_ORIGINS": "https://viraltrim.codedmotion.studio",
    "SESSION_TTL": "604800",
    "GEMINI_MODEL": "gemini-1.5-flash",
    "RESEND_FROM_EMAIL": "hello@viraltrim.com",
    "RESEND_ADMIN_EMAIL": "admin@viraltrim.com",
    "STRIPE_PRO_PRICE_ID": "",
    "STRIPE_AGENCY_PRICE_ID": ""
  }
}
