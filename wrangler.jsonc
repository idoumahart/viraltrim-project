{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "viraltrim",
  "main": "worker/index.ts",
  "compatibility_date": "2025-04-24",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "viraltrim-db",
      "database_id": "b58660ce-ed5b-49fc-bc5e-87e1ecc3dda8"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "REPLACE_WITH_KV_SESSIONS_ID"
    },
    {
      "binding": "CACHE",
      "id": "REPLACE_WITH_KV_CACHE_ID"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "viraltrim-media"
    }
  ],
  "vars": {
    "APP_URL": "https://viraltrim.codedmotion.studio",
    "ALLOWED_ORIGINS": "https://viraltrim.codedmotion.studio,http://localhost:3000",
    "SESSION_TTL": "604800",
    "GEMINI_MODEL": "gemini-2.0-flash",
    "RESEND_FROM_EMAIL": "hello@viraltrim.com",
    "RESEND_ADMIN_EMAIL": "admin@viraltrim.com",
    "STRIPE_PRO_PRICE_ID": "",
    "STRIPE_AGENCY_PRICE_ID": ""
  }
}
